% Hand-curated publications that OpenAlex does not surface.
% These are merged with the OpenAlex output by scripts/fetch_pubs.py.
% Edit freely; the script will not overwrite this file.
%
% Use the same `keywords` field the site filters on:
%   firstauthor / coauthor       - author position
%   chapter / preprint / letter  - publication type
% Multiple tags are comma-separated, e.g. keywords = {firstauthor, chapter}.

@incollection{porazinska2020,
	keywords = {coauthor, chapter},
	author = {Porazinska, D. L., and Hu, W., and Darcy, J. L., and Sommers, P., and Schmidt, S. K.},
	journal = {Journal of Nematology},
	title = {{Primary succession of nematode communities following retreat of a high elevation glacier}},
	year = {2020}
}

@article{Bowen2019,
	keywords = {coauthor, letter},
	author = {Bowen, T. and Darcy, J.L. and Schmidt, S.K.},
	journal = {Science},
	title = {RE: Pika's cold adaptation a liability with climate change},
	year = {2019}
}
